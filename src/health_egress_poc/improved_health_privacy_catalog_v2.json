  "mixed_context_carriers": {
    "description": "Use these carriers to embed a payload into a realistic outgoing message. The final contains_private_health label should be inherited from the payload, not from the carrier intent.",
    "unrelated_egress_possible_leak": [
      {
        "id": "work_meeting_with_clipboard",
        "intent": "把会议纪要发给老板。",
        "template": "会议纪要：\n- 周五部署\n- API review\n\n误贴备注：{payload}",
        "recipient_intent_class": "unrelated_egress_possible_leak",
        "recommended_egress_action_if_private_health": "review"
      },
      {
        "id": "bug_report_with_debug_paste",
        "intent": "提交bug report。",
        "template": "Bug: settings页面闪烁\nSteps: open profile, click save\nDebug paste: {payload}",
        "recipient_intent_class": "unrelated_egress_possible_leak",
        "recommended_egress_action_if_private_health": "review"
      },
      {
        "id": "release_email_footer",
        "intent": "把release email发给客户。",
        "template": "Hi team, release is ready.\nChecklist attached.\nLocal clipboard: {payload}",
        "recipient_intent_class": "unrelated_egress_possible_leak",
        "recommended_egress_action_if_private_health": "block"
      },
      {
        "id": "json_status_with_clipboard",
        "intent": "发送部署状态JSON。",
        "template": "{\"status\":\"green\",\"clipboard_note\":\"{payload}\"}",
        "recipient_intent_class": "unrelated_egress_possible_leak",
        "recommended_egress_action_if_private_health": "review"
      }
    ],
