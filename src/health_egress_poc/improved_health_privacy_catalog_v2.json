{
  "version": "health_privacy_catalog_v2",
  "language": "zh-Hans",
  "purpose": "Generate synthetic Simplified Chinese mixed-context examples for classifying whether text contains private health data.",
  "label_schema": {
    "contains_private_health": {
      "type": "boolean",
      "definition": "True if the text reveals an individual's health condition, diagnosis, medication, test result, appointment, medical bill/claim, vaccination record, wearable/vital data, mental health state, or medical document."
    },
    "health_privacy_subtype": [
      "diagnosis_condition",
      "symptom_history",
      "medication_prescription",
      "lab_result",
      "appointment_visit",
      "insurance_claim",
      "medical_bill",
      "wearable_vitals",
      "vaccination_record",
      "mental_health",
      "medical_document",
      "family_health"
    ],
    "contains_other_private": {
      "type": "boolean",
      "definition": "True if the text contains non-health sensitive data such as finance, identity, address, account, work confidential data, or credentials."
    },
    "content_class": [
      "private_health",
      "non_private_health",
      "benign",
      "other_private_non_health"
    ],
    "recipient_intent_class": [
      "authorized_health_sharing",
      "unrelated_egress_possible_leak",
      "public_or_general_discussion",
      "non_health_task"
    ],
    "recommended_egress_action": [
      "allow",
      "review",
      "block"
    ],
    "important_rule": "For centroid/content classification, accidental paste of private health payload into a work message must still have contains_private_health=true. Intent is a separate field."
  },
